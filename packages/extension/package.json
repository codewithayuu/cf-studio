{
  "name": "@cf-studio/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:chrome": "node build.mjs --browser=chrome",
    "build:firefox": "node build.mjs --browser=firefox",
    "dev:chrome": "node build.mjs --browser=chrome --watch",
    "dev:firefox": "node build.mjs --browser=firefox --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cf-studio/shared": "workspace:*",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.12.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
